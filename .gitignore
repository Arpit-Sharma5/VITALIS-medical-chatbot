# ─── Environment & Secrets ────────────────────────────────
.env
.env.local
.env.*.local

# ─── Python ───────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so

# ─── Virtual Environments ────────────────────────────────
.venv/
venv/
ENV/
env/

# ─── Distribution / Packaging ────────────────────────────
build/
dist/
*.egg-info/
*.egg
eggs/
*.whl

# ─── Jupyter Notebooks ──────────────────────────────────
.ipynb_checkpoints/

# ─── IDE / Editor ────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/

# ─── OS Generated ───────────────────────────────────────
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
Desktop.ini

# ─── Pinecone / Model Caches ────────────────────────────
*.index
*.faiss
